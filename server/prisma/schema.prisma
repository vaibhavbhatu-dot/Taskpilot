generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  PROJECT_MANAGER
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum TicketType {
  BUG
  FEATURE
  TASK
  IMPROVEMENT
}

enum TicketPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketStatus {
  BACKLOG
  REQUIREMENTS
  DESIGN
  HTML
  ON_DEVELOPMENT
  QA
  BUGS
  ENHANCEMENT
  UAT
  LIVE
  NOT_REQUIRED
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum NotificationType {
  TICKET_ASSIGNED
  TICKET_UPDATED
  TICKET_COMMENTED
  SPRINT_STARTED
  SPRINT_COMPLETED
  INVITATION_SENT
  MENTION
  OVERDUE
}

enum SupportCategory {
  BUG
  FEATURE
  ACCOUNT
  BILLING
  OTHER
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── MODELS ──────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  projects       Project[]
  teams          Team[]
  sprints        Sprint[]
  supportTickets SupportTicket[]
  invitations    Invitation[]
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String
  fullName    String
  designation String?
  role        UserRole   @default(MEMBER)
  managerId   String?
  teamId      String?
  avatar                String?
  status                UserStatus @default(ACTIVE)
  emailVerified         Boolean    @default(false)
  timezone              String?
  onboardingCompleted   Boolean    @default(false)
  organizationId        String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  organization  Organization?  @relation(fields: [organizationId], references: [id])
  manager       User?          @relation("UserManager", fields: [managerId], references: [id])
  subordinates  User[]         @relation("UserManager")
  team          Team?          @relation("TeamMembers", fields: [teamId], references: [id])
  ledTeams      Team[]         @relation("TeamLead")
  ledProjects   Project[]      @relation("ProjectLead")
  createdTickets   Ticket[]    @relation("TicketCreator")
  assignedTickets  Ticket[]    @relation("TicketAssignee")
  createdSprints   Sprint[]    @relation("SprintCreator")
  comments         Comment[]
  notifications    Notification[]
  ticketHistoryChanges TicketHistory[]
  sentInvitations  Invitation[] @relation("InvitationSender")
  ticketAssignments TicketAssignee[] @relation("TicketAssigneeUser")
  uploadedAttachments Attachment[] @relation("AttachmentUploader")
  supportTickets      SupportTicket[]
  supportMessages     SupportMessage[]

  @@index([email])
  @@index([teamId])
  @@index([managerId])
  @@index([organizationId])
}

model Team {
  id             String   @id @default(uuid())
  name           String
  leadId         String?
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization? @relation(fields: [organizationId], references: [id])
  lead         User?          @relation("TeamLead", fields: [leadId], references: [id])
  members      User[]         @relation("TeamMembers")
  tickets      Ticket[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Invitation {
  id              String           @id @default(uuid())
  email           String
  token           String           @unique
  invitedById     String
  organizationId  String?
  presetRole      UserRole         @default(MEMBER)
  presetManagerId String?
  presetTeamId    String?
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime
  createdAt       DateTime         @default(now())

  // Relations
  invitedBy    User          @relation("InvitationSender", fields: [invitedById], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([token])
  @@index([email])
  @@index([organizationId])
}

model Project {
  id             String        @id @default(uuid())
  name           String
  key            String
  leadId         String?
  organizationId String?
  status         ProjectStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  organization Organization? @relation(fields: [organizationId], references: [id])
  lead         User?          @relation("ProjectLead", fields: [leadId], references: [id])
  tickets      Ticket[]
  sprints      Sprint[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

model Ticket {
  id           String         @id @default(uuid())
  ticketNumber String
  projectId    String
  title        String
  description  String?
  type         TicketType     @default(TASK)
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus   @default(BACKLOG)
  createdById  String
  assignedToId String?
  teamId       String?
  dueDate      DateTime?
  completedAt  DateTime?
  labels       String[]       @default([])
  links        String[]       @default([])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  project       Project        @relation(fields: [projectId], references: [id])
  createdBy     User           @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo    User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  team          Team?          @relation(fields: [teamId], references: [id])
  comments      Comment[]
  history       TicketHistory[]
  sprintTickets SprintTicket[]
  assignees     TicketAssignee[]
  attachments   Attachment[]

  @@unique([projectId, ticketNumber])
  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
}

model Sprint {
  id             String       @id @default(uuid())
  name           String
  projectId      String
  startDate      DateTime?
  endDate        DateTime?
  goal           String?
  status         SprintStatus @default(PLANNED)
  createdById    String
  organizationId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  organization  Organization?  @relation(fields: [organizationId], references: [id])
  project       Project        @relation(fields: [projectId], references: [id])
  createdBy     User           @relation("SprintCreator", fields: [createdById], references: [id])
  sprintTickets SprintTicket[]

  @@index([projectId])
  @@index([status])
  @@index([organizationId])
}

model SprintTicket {
  id             String       @id @default(uuid())
  sprintId       String
  ticketId       String
  statusAtStart  TicketStatus

  // Relations
  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([sprintId, ticketId])
}

model TicketHistory {
  id           String   @id @default(uuid())
  ticketId     String
  changedById  String
  fieldChanged String
  oldValue     String?
  newValue     String?
  changedAt    DateTime @default(now())

  // Relations
  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id])

  @@index([ticketId])
  @@index([changedAt])
}

model Comment {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id])
  parent      Comment?     @relation("CommentThread", fields: [parentId], references: [id])
  replies     Comment[]    @relation("CommentThread")
  attachments Attachment[] @relation("CommentAttachments")

  @@index([ticketId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model TicketAssignee {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  assignedAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation("TicketAssigneeUser", fields: [userId], references: [id])

  @@unique([ticketId, userId])
  @@index([ticketId])
  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  otp       String
  type      String   @default("EMAIL_VERIFY")
  expiresAt DateTime
  createdAt DateTime @default(now())
  attempts  Int      @default(0)

  @@index([email])
}

model Attachment {
  id           String   @id @default(uuid())
  ticketId     String
  filename     String
  originalName String
  url          String
  size         Int?
  mimeType     String?
  uploadedById String
  commentId    String?
  createdAt    DateTime @default(now())

  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  comment    Comment? @relation("CommentAttachments", fields: [commentId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([commentId])
}

model SupportTicket {
  id                     String          @id @default(uuid())
  ticketNumber           String          @unique
  userId                 String
  organizationId         String
  category               SupportCategory
  subject                String
  description            String
  attachmentUrl          String?
  status                 SupportStatus   @default(OPEN)
  priority               SupportPriority @default(MEDIUM)
  expectedResolutionDate DateTime?
  resolvedAt             DateTime?
  autoCloseAt            DateTime?
  metadata               Json?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  user         User           @relation(fields: [userId], references: [id])
  organization Organization   @relation(fields: [organizationId], references: [id])
  messages     SupportMessage[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
}

model SupportMessage {
  id            String   @id @default(uuid())
  ticketId      String
  authorId      String?
  isAdminReply  Boolean  @default(false)
  content       String
  attachmentUrl String?
  createdAt     DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User?         @relation(fields: [authorId], references: [id])

  @@index([ticketId])
}
